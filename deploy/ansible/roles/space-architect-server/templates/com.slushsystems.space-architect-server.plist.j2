<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>{{ server_label }}</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>{{ server_dir }}/run-server.sh</string>
  </array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>StandardOutPath</key><string>{{ ansible_env.HOME }}/Library/Logs/space-architect-server.log</string>
  <key>StandardErrorPath</key><string>{{ ansible_env.HOME }}/Library/Logs/space-architect-server.log</string>
</dict>
</plist>
