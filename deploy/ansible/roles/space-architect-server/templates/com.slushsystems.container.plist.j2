<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>{{ container_label }}</string>
  <key>ProgramArguments</key>
  <array>
    <string>{{ container_bin }}</string>
    <string>system</string>
    <string>start</string>
  </array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>StandardOutPath</key><string>{{ ansible_env.HOME }}/Library/Logs/container-system.log</string>
  <key>StandardErrorPath</key><string>{{ ansible_env.HOME }}/Library/Logs/container-system.log</string>
</dict>
</plist>
