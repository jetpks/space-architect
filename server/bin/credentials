#!/usr/bin/env ruby
# frozen_string_literal: true
#
# Edit the encrypted credentials file (config/credentials.yml.enc), Rails-style.
#
# Generates config/master.key on first run if no key is present (via ARCHITECT_MASTER_KEY
# or the key file). Decrypts into a temp YAML file, opens $EDITOR/$VISUAL (falling back
# to vi), then re-encrypts on save. The master key stays out of git (gitignored); the
# encrypted file is safe to commit. Resolution at runtime is ENV-first, then this file.
#
#   bin/credentials                          # interactive edit
#   EDITOR='code --wait' bin/credentials     # a specific editor
#   EDITOR=./script.sh   bin/credentials     # scripted edit ($1 = the temp YAML file)

require "openssl"
require "securerandom"
require "shellwords"
require "tempfile"

Dir.chdir(File.expand_path("..", __dir__)) # run from the architect root
$LOAD_PATH.unshift File.expand_path("../gems/hanami-credentials/lib") # in-tree gem, no bundler needed
require "hanami_credentials"

CONTENT_PATH = "config/credentials.yml.enc"
KEY_PATH     = "config/master.key"
ENV_KEY      = "ARCHITECT_MASTER_KEY"

key = HanamiCredentials.read_key(env_key: ENV_KEY, key_path: KEY_PATH)
if key.nil?
  hex = SecureRandom.hex(32) # 64 hex chars = 32 raw bytes
  File.write(KEY_PATH, hex)
  File.chmod(0o600, KEY_PATH)
  key = [hex].pack("H*")
  warn "[bin/credentials] generated #{KEY_PATH} — gitignored; back it up / share out-of-band"
end

ef = HanamiCredentials::EncryptedFile.new(content_path: CONTENT_PATH, key: key)

current =
  if File.exist?(CONTENT_PATH)
    begin
      ef.read
    rescue OpenSSL::Cipher::CipherError
      warn "[bin/credentials] #{CONTENT_PATH} won't decrypt with this key (stale placeholder?) — starting fresh"
      ""
    end
  else
    ""
  end

editor = ENV["EDITOR"] || ENV["VISUAL"] || "vi"

edited = Tempfile.create(["credentials", ".yml"]) do |tmp|
  tmp.write(current.to_s.empty? ? "---\n" : current)
  tmp.flush
  unless system(*Shellwords.split(editor), tmp.path)
    abort "[bin/credentials] editor (#{editor}) exited non-zero — credentials unchanged"
  end
  File.read(tmp.path)
end

abort "[bin/credentials] empty content — credentials unchanged" if edited.to_s.strip.empty?

ef.write(edited)
warn "[bin/credentials] encrypted → #{CONTENT_PATH}"
